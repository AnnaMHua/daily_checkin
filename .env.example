# Optional. Copy this file to .env and adjust the values.
# If LaunchAgent is installed, rerun ./scripts/install_launchagent.sh after
# changing .env so the deployed background copy receives the update.

# Use the Chrome profile that is already logged in to 1Point3Acres.
# On this Mac, the normal profile directory is usually "Default".
CHROME_PROFILE_DIRECTORY=Default

# Optional. Set this only if Chrome is installed somewhere unusual.
# CHROME_EXECUTABLE=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# The check-in page accepts arbitrary short text. Separate multiple messages with "|".
DAILY_CHECKIN_MESSAGES="今天也来打卡|保持学习，继续加油|签到一下"
