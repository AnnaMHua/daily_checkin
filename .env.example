# Recommended. Copy this file to .env and adjust the values.
# If LaunchAgent is installed, rerun ./scripts/install_launchagent.sh after
# changing .env so the deployed background copy receives the update.

# Default mode uses a dedicated visible Chrome profile through CDP. The first
# setup run opens this profile so you can log in and complete any verification.
CHROME_CONTROL_MODE=cdp
CHROME_CDP_ADDRESS=127.0.0.1
CHROME_CDP_PORT=9223
CHROME_USER_DATA_DIR="$HOME/Library/Application Support/daily_checkin/chrome-profile"

# This is the internal profile directory inside CHROME_USER_DATA_DIR. It is not
# always the same as the Chrome UI display name. For example, a Chrome profile
# displayed as "13checkin" may be stored as "Profile 1".
CHROME_PROFILE_DIRECTORY=Default

# Optional. Set this only if Chrome is installed somewhere unusual.
# CHROME_EXECUTABLE=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Random delay before each real click. Keep this for page stability; it is not
# intended to bypass login checks or human verification.
CLICK_WAIT_MIN_SECONDS=0.8
CLICK_WAIT_MAX_SECONDS=2.4

# LaunchAgent starts at the scheduled minute, then waits a random amount before
# opening Chrome. With a 00:05 schedule, 0-600 seconds means 00:05-00:15.
LAUNCH_RANDOM_DELAY_MIN_SECONDS=0
LAUNCH_RANDOM_DELAY_MAX_SECONDS=600

# The check-in page accepts arbitrary short text. Separate multiple messages with "|".
DAILY_CHECKIN_MESSAGES="今天也来打卡|保持学习，继续加油|签到一下"
